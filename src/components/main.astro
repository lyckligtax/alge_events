---
import LogoRund from "../assets/logo_rund.png"
import BetterPlace from "../assets/betterplace-qr-code.png"
import Buch from "../assets/buch.webp"
---
<style>
    .content {
        width: 100%;
        font-size: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;

        & > section {
            width: 100%;
            max-width: var(--content-width);
            padding: 60px 30px;
            box-sizing: border-box;
        }
    }

    #date {
        background: var(--yellow);
        font-size: 30px;

        & > section {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        & .date {
            font-size: 40px;
            font-weight: bold;
        }
    }

    #about {
        background: #F8F7F2;

        & > section {
            display: flex;

            & img {
                height: 200px;
                margin-right: 50px;
            }

            & .description {
                & > div {
                    margin-bottom: 20px;
                }

                line-height: 30px;
                text-align: justify;
            }
        }
    }

    #spenden {
        background: #000;

        & > section {
            & div {
                margin-bottom: 20px;
            }
        }

        .betterplace {
            display: flex;

            line-height: 30px;
            text-align: justify;
            & img {
                height: 100px;
                margin-right: 60px;
            }
        }

        color: whitesmoke;
    }

    #lesung {
        background: #072D60;
        color: whitesmoke;

        & > section > div {
            margin-bottom: 30px;
        }

        & .content {
            display: flex;
            flex-direction: row;
            line-height: 30px;
            text-align: justify;
            align-items: flex-start;

            & > div > div {
                margin-bottom: 20px;
            }

            & img {
                margin-left: 60px;
                width: 460px;
            }
        }
    }

    #location {
        & > section {
            padding: 0;
            display: flex;

            & .address {
                display: flex;

                & > div:first-of-type {
                    margin-right: 60px;
                }
            }

            & > iframe {
                margin-right: 60px;
            }

            & > div {
                padding-top: 60px;
            }
        }
    }

    #tickets {
        background: var(--yellow);

        & > section {
            display: flex;
            justify-content: center;

            & > form {
                display: flex;
                flex-direction: column;

                & label {
                    margin-bottom: 8px;
                }

                & input[type=email] {
                    padding: 10px 20px;
                    background: transparent;
                    border: 2px solid #000;
                    border-radius: 8px;
                    margin-bottom: 12px;
                }

                & input[type="radio"] {
                    accent-color: #000;
                    transform: scale(1.5);
                    margin-right: 8px;
                }

                & .disclaimer {
                    margin-top: 12px;
                }

                & button {
                    margin-top: 8px;
                    background: #000;
                    color: var(--yellow);
                    font-size: 20px;
                    border-radius: 8px;
                    padding: 16px 20px;
                    border: none
                }
            }

            & > div {
            }
        }
    }
</style>
<div class="content" id="date">
    <section>
        <div class="date">14.06.2026 - 17:00</div>
        <div>Hamburg und per Stream</div>
    </section>
</div>
<div class="content" id="about">
    <section>
        <div>
            <img src={LogoRund.src}>
        </div>
        <div class="description">
            <h2>Über den Verein</h2>
            <div>
                <a href="https://alge-hamburg.de">alge-hamburg.de</a>
            </div>
            <div>Der ALGE e.V. ist ein gemeinnütziger Verein, der sich deutschlandweit für infektionssichere
                Freizeitangebote und einen infektionssensiblen Alltag stark macht. Wir bieten regelmäßige virtuelle
                Aktivitäten sowie Präsenz-Veranstaltungen mit individuell angepassten Infektionsschutzkonzepten (Tests,
                Masken, Luftfilter, …).<br>
                Wir wollen Menschen zusammenbringen, die sich aus vielfältigen Gründen vor Infektionen schützen wollen
                oder müssen. Unser Ziel ist es, gemeinsam Infektionsschutz (vor-)zuleben und zu zeigen, wie
                Infektionsschutz ein selbstverständlicher Teil von Freizeitaktivitäten sein kann.
            </div>
            <div>Wir bieten digitale Veranstaltungen wie:
                <ul>
                    <li>Brettspielabende</li>
                    <li>Klönabende</li>
                    <li>Kreativ-Cafés</li>
                    <li>Brunch</li>
                </ul>
            </div>
            <div>
                und infektionssensible Präsenz-Veranstaltungen wie:
                <ul>
                    <li>Wander- und Klettergruppe</li>
                    <li>Vernetzungstreffen</li>
                    <li>Testessen zu Hamburgs besten Franzbrötchen</li>
                    <li>Weihnachtsfeier</li>
                    <li>Kinder-Freizeitangebote</li>
                </ul>
            </div>
        </div>
    </section>
</div>
<div class="content" id="lesung">
    <section>
        <h2>Über die Lesung</h2>
        <div class="content">
            <div>
                <div><b>"Die verdrängte Pandemie - Linke Stimmen gegen den Pandemierevisionismus"</b> mit den Herausgebern
                    Frédéric Valin und Paul Schubert.
                </div>
                <div>Fast 7 Jahre ist es her, seit der erste Covid-19 Fall bei München entdeckt wurde und die tödliche Covid-19
                    Pandemie ihren Lauf genommen hat. Seit der Aufhebung der staatlichen Schutzmaßnahmen macht sich in allen
                    politischen Lagern ein Pandemierevisionismus breit. Die Gefahren des Virus werden verharmlost,
                    Gesundheitsschutz lächerlich gemacht, an Long Covid leidende Menschen werden stigmatisiert und die
                    Bedürfnisse von vulnerablen Personen kommen in der Diskussion kaum mehr vor.
                </div>
                <div>Die Herausgeber Frédéric Valin und Paul Schubert beleuchten in ihrem Sammelband „Die verdrängte Pandemie –
                    Linke Stimmen gegen den Pandemierevisionismus“ mit Beiträgen von Autor*innen und Wissenschaftler*innen wie
                    Natascha Strobl und Thomas Ebermann u.A. die Rolle von Behindertenfeindlichkeit und Sozialdarwinismus
                    während und nach der Pandemie und fragen, wie gesellschaftliche Teilhabe für alle möglich bleibt. Dazu laden
                    wir euch ganz herzlich zur Lesung mit den Herausgebern ein.
                </div>
                <div>Neben einer kurzen Sozialgeschichte der Pandemie werden auch die Rolle des Staates während der Pandemie,
                    die Zustände der Gesundheitssysteme und die mangelnde Versorgung für Long-Covid- und ME/ CFS-Patient*innen
                    behandelt.
                </div>
                <div>Der Eintritt ist frei, wir bitten allerdings um Anmeldung. Für die gesamte Veranstaltung gilt der <a
                        href="https://alge-hamburg.de/coc">Code of Conduct</a> des ALGE e.V..
                </div>
            </div>
            <div>
                <img src={Buch.src}/>
            </div>
        </div>
    </section>
</div>
<div class="content" id="spenden">
    <section>
        <h2>Spenden</h2>
        <div class="betterplace">
            <div><img src={BetterPlace.src}/></div>
            <div>
                <div>Unser Verein setzt sich mit viel Engagement für diese Lesung und weitere Veranstaltungen ein. Damit
                    wir unsere wichtige Arbeit auch weiterhin fortführen und ausbauen können, sind wir auf eure Hilfe
                    angewiesen.
                </div>
                <div>Jede Spende, egal in welcher Höhe, trägt dazu bei, unsere Projekte zu realisieren um gemeinsam für
                    ein sicheres Miteinander zu arbeiten.
                </div>
                <div>
                    Unterstützen könnt ihr uns ganz einfach über <a
                        href="https://www.betterplace.org/de/projects/140795">Betterplace</a>. Eine Spendenquittung für
                    die Steuer stellen wir natürlich gerne aus.
                </div>
            </div>
        </div>
        <div></div>
    </section>
</div>
<div class="content" id="location">
    <section>
        <iframe width="600" height="600"
                src="https://www.openstreetmap.org/export/embed.html?bbox=9.941739141941072%2C53.557417871169264%2C9.946996271610262%2C53.559449251254975&amp;layer=mapnik"
                style="border: none"></iframe>
        <div>
            <h2>Live Location</h2>
            <div class="address">
                <div>
                    CCC Hansestadt Hamburg e.V.<br>
                    Zeiseweg 9<br>
                    22765 Hamburg
                </div>
                <div>
                    Rollstuhlgerecht<br>
                    Toiletten<br>
                    Getränke<br>
                    Käsekuchen
                </div>
            </div>
            <h2>Und per Stream</h2>
            <div>Link nach Anmeldung</div>
        </div>
    </section>
</div>
<div class="content" id="tickets">
    <section>
        <form id="ticketForm" action="https://formy.alge-hamburg.de/register/df9d7b1b-e08c-4ff6-aeee-818a976ef282"
              method="post">
            <label>eMail Adresse</label>
            <input type="email" name="email"/>
            <label>Teilnahme</label>
            <label><input type="radio" name="inPresence" value="true" checked/> Ich komme vorbei</label>
            <label><input type="radio" name="inPresence" value="false"/> Ich nehme online teil</label>
            <div class="disclaimer">
                Mit der Anmeldung akzeptierst du den <a href="https://alge-hamburg.de/coc">Code of Conduct</a> des ALGE e.V.
            </div>
            <button type="submit">ZUR LESUNG ANMELDEN</button>
        </form>
    </section>
</div>

<script>
    const handleSubmit = (event) => {
        event.preventDefault();

        const myForm = event.target;

        fetch(event.target.action, {
            method: "POST",
            headers: {"Content-Type": "application/x-www-form-urlencoded"},
            body: new FormData(myForm)
        })
            .then(() => {
                event.target.reset()
                console.log("Form successfully submitted")
            })
            .catch(error => {
                console.log(error);
                console.log("Error Submiting Form", error)
            });
    };

    document.getElementById("ticketForm").addEventListener("submit", handleSubmit);
</script>