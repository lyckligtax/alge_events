<style>
    #registration {
        background: var(--yellow);

        & > div {
            display: flex;
            justify-content: center;

            & > form {
                display: flex;
                flex-direction: column;

                & label {
                    margin-bottom: 8px;
                }

                & input[type=email] {
                    padding: 1rem 2rem;
                    background: transparent;
                    border: 2px solid #000;
                    border-radius: 8px;
                    margin-bottom: 1rem;
                    line-height: 1.2rem;
                    font-size: 1.2rem;
                }

                & input[type="radio"] {
                    accent-color: #000;
                    transform: scale(1.5);
                    margin-right: 8px;
                }

                & .disclaimer {
                    margin-top: 12px;
                }

                & button {
                    margin-top: 8px;
                    background: #000;
                    color: var(--yellow);
                    font-size: 1.2rem;
                    line-height: 1.2rem;
                    border-radius: 8px;
                    padding: 1rem 2rem;
                    border: 2px solid #000;
                }
            }
        }

        & .formHidden {
            display: none;
        }

        & .message {
            margin-top: 8px;
            font-size: 1.2rem;
            line-height: 1.2rem;
            border-radius: 8px;
            padding: 1rem 2rem;
            border: 2px solid #000;
            text-align: center;
        }
    }
</style>
<section class="content-container" id="registration">
    <div class="text-content">
        <h2>Registrierung</h2>
        <form id="registrationForm" action="https://formy.alge-hamburg.de/register/df9d7b1b-e08c-4ff6-aeee-818a976ef282"
              method="post">
            <label>eMail Adresse</label>
            <input type="email" name="email"/>
            <label>Teilnahme</label>
            <label><input type="radio" name="inPresence" value="true" checked/> Ich komme vorbei</label>
            <label><input type="radio" name="inPresence" value="false"/> Ich nehme online teil</label>
            <div class="disclaimer">
                Mit der Anmeldung akzeptierst du den <a href="https://alge-hamburg.de/coc">Code of Conduct</a> des ALGE e.V.
            </div>
            <div id="registrationOSuccess" class="formHidden message">
                Vielen Dank für deine Anmeldung.
            </div>
            <div id="registrationError" class="formHidden message">
                Leider gab es einen Fehler bei der Anmeldung. Bitte probiere es später erneut oder melde dich per <a href="mailto:info@alge-hamburg.de">Mail</a>
            </div>
            <button id="registrationSubmit" type="submit">ZUR LESUNG ANMELDEN</button>
            <div id="registrationOSuccess" class="formHidden message">
                Vielen Dank für deine Anmeldung
            </div>
            <div id="registrationError" class="formHidden message">
                Leider gab es einen Fehler bei der Anmeldung. Bitte probiere es später erneut oder melde dich bei uns per <a href="mailto:info@alge-hamburg.de">Mail</a>
            </div>
        </form>
    </div>
</section>

<script>
    const handleSubmit = (event) => {
        event.preventDefault();

        const myForm = event.target;
        const formData = new FormData(myForm);

        fetch(event.target.action, {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: new URLSearchParams(formData).toString()
        })
            .then(() => {
                event.target.reset()
                document.getElementById("registrationOSuccess")?.classList.remove("formHidden");
            })
            .catch(error => {
                console.log(error);
                document.getElementById("registrationError")?.classList.remove("formHidden");
            });
    };

    document.getElementById("registrationForm").addEventListener("submit", handleSubmit);
</script>