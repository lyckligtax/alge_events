<style>
    #location {
        display: flex;
        flex-direction: row;
    }

    iframe {
        width: 50%;
        height: 30rem;
    }

    .text-content {
        padding-left: 3rem;
        justify-content: center;
    }
    @media only screen and (hover: none) and (pointer: coarse){
        #location {
            flex-direction: column-reverse;
        }
        .text-content {
            padding: 3rem 0 3rem 1.5rem;
            justify-content: unset;
        }
        iframe {
            width: 100%;
            height: 26rem;
        }
    }
</style>
