---
const {
        image,
    name
    } = Astro.props
---
<div class="author">
    <img src={image}>
    <div class="name">{name}</div>
</div>

<style>
    .author {
        display: flex;
        flex-direction: column;
        align-items: center;
        & > img {
            border-radius: 5000px;
            height: 250px;
            width: 250px;
        }
        & > .name {
            margin-top: 16px;
            color: white;
            font-size: 30px;
        }
    }
</style>