---
import NavItem from "./nav_item.astro"
import Logo from "../assets/logo.png"
---
<nav>
    <img id="logo" src={Logo.src}/>
    <NavItem name="ÜBER UNS" link="#about"/>
    <NavItem name="DIE LESUNG" link="#lesung"/>
    <NavItem name="SPENDEN" link="#spenden"/>
    <NavItem name="LOCATION" link="#location"/>
    <a class="ticketLink" href="#registration">SEI DABEI</a>
</nav>

<style>
    nav {
        z-index: 1;
        height: 5rem;
        position: fixed;
        top: 0;
        background: black;
        width: 100%;
        font-size: 1.2rem;
        text-decoration: none;
        font-weight: 500;
        padding: 1rem 0;
        display: flex;
        align-items: center;
        align-content: center;
        box-sizing: border-box;
        justify-content: right;
        max-width: var(--content-width);
    }

    #logo {
        margin-left: 3rem;
        margin-right: auto;
        height: 3rem;
    }

    .ticketLink {
        border: 2px solid #F4BB46;
        background: #F4BB46;
        border-radius: 0.8rem;
        padding: 0.5rem 1.5rem;
        color: black;
        font-weight: 500;
        text-decoration: none;
        margin-right: 3rem;
    }

    @media only screen and (hover: none) and (pointer: coarse) {
        .ticketLink {
            display: none;
        }

        #logo {
            margin-left: 1rem;
        }
    }
</style>